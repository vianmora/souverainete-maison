# ============================================================
# Variables d'environnement : copier ce fichier en .env
# et remplacer chaque CHANGEME. Le .env est ignoré par git
# et ne doit JAMAIS être commité.
#
#   cp .env.example .env
#
# Générer un mot de passe fort :
#   openssl rand -base64 32
# ============================================================

# ---- Général ------------------------------------------------
TZ=Europe/Paris

# Domaine racine. Chaque service vit sur un sous-domaine :
# nextcloud.exemple.fr, n8n.exemple.fr, status.exemple.fr...
DOMAIN=exemple.fr

# ---- Cloudflare Tunnel (docs/cloudflare-tunnel.md) ----------
# Token fourni par le dashboard Zero Trust à la création du tunnel.
CLOUDFLARE_TUNNEL_TOKEN=CHANGEME

# ---- Homepage -----------------------------------------------
# Domaines autorisés à afficher le dashboard (anti host-header spoofing)
HOMEPAGE_ALLOWED_HOSTS=maison.exemple.fr

# ---- n8n ----------------------------------------------------
N8N_HOST=n8n.exemple.fr
N8N_POSTGRES_PASSWORD=CHANGEME
# Clé de chiffrement des credentials n8n. À générer une fois,
# puis à SAUVEGARDER précieusement : sans elle, les credentials
# stockés en base sont irrécupérables.
N8N_ENCRYPTION_KEY=CHANGEME

# ---- Umami --------------------------------------------------
UMAMI_POSTGRES_PASSWORD=CHANGEME
# Secret de session, chaîne aléatoire quelconque
UMAMI_APP_SECRET=CHANGEME

# ---- Listmonk -----------------------------------------------
LISTMONK_POSTGRES_PASSWORD=CHANGEME
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=CHANGEME

# ---- EspoCRM ------------------------------------------------
ESPOCRM_DB_ROOT_PASSWORD=CHANGEME
ESPOCRM_DB_PASSWORD=CHANGEME
ESPOCRM_ADMIN_PASSWORD=CHANGEME
ESPOCRM_SITE_URL=https://crm.exemple.fr

# ---- Mautic -------------------------------------------------
MAUTIC_DB_ROOT_PASSWORD=CHANGEME
MAUTIC_DB_PASSWORD=CHANGEME
MAUTIC_SITE_URL=https://mautic.exemple.fr

# ---- Invoice Ninja ------------------------------------------
IN_DB_ROOT_PASSWORD=CHANGEME
IN_DB_PASSWORD=CHANGEME
# Générer avec : docker run --rm invoiceninja/invoiceninja:5 php artisan key:generate --show
IN_APP_KEY=CHANGEME
IN_APP_URL=https://factures.exemple.fr

# ---- Hi.Events ----------------------------------------------
HIEVENTS_POSTGRES_PASSWORD=CHANGEME
# openssl rand -base64 32
HIEVENTS_APP_KEY=base64:CHANGEME
HIEVENTS_JWT_SECRET=CHANGEME
HIEVENTS_APP_URL=https://billetterie.exemple.fr

# ---- Monitoring ---------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGEME
